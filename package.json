    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@tiptap/core": "^3.4.1",
    "@tiptap/markdown": "^3.4.1",
    "@tiptap/pm": "^3.4.1",
    "@tiptap/starter-kit": "^3.4.1",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "serve": "^14.2.4",
    "typescript": "~5.9.2"
  },
  "packageManager": "npm@11.10.1"
